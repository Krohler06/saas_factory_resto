      "position": [
        1200,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "return [{ json: { ...$json, event_message: `Bonjour, une information importante concerne votre réservation. Merci de votre compréhension.` } }];"
      },
      "id": "wf_evt_006",
      "name": "Build Message",
