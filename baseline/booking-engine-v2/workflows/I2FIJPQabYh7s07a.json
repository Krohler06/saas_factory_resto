      "credentials": {
        "postgres": {
          "id": "oIKfFfyMDZkHhOm4",
          "name": "Postgres Little Africa"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{$json.consent_notifications}}",
              "operation": "isTrue"
