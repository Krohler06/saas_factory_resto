    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT * FROM restaurant_closures WHERE restaurant_id = {{$json.restaurant_id}} AND is_active = true ORDER BY starts_at DESC LIMIT 1;"
      },
      "id": "wf_evt_002",
      "name": "Get Event Context",
      "type": "n8n-nodes-base.postgres",
