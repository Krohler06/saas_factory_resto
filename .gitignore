###############################################################################
# Secrets et environnements
###############################################################################

.env
.env.*
!.env.example
!*.env.example

*.pem
*.key
*.crt
*.p12
*.pfx

###############################################################################
# Sauvegardes, exports et fichiers runtime
###############################################################################

/backups/
/exports/
/generated/
/baseline/

/tenants/private/

*.dump
*.backup
*.tgz
*.tar
*.tar.gz
*.zip
*.gz

###############################################################################
# Python
###############################################################################

__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.venv/
venv/

###############################################################################
# Fichiers temporaires
###############################################################################

*.bak
*.bak.*
*.old
*.orig
*.tmp
*.temp
*.swp
*.swo
*~

###############################################################################
# Logs et rapports générés
###############################################################################

*.log
*.pid
*.retry

/docs/BOOKING_ENGINE_V2_BASELINE.md

###############################################################################
# Artefacts spécifiques à une promotion ou à un tenant
###############################################################################

/template/PROMOTED_FROM.txt
/template/tenant_manifest.reference.json

/template/caddy/routes.reference.txt

/template/docker/*resolved*
/template/docker/*exported*
/template/docker/*reference*

###############################################################################
# Environnement template
###############################################################################

/template/env/*
!/template/env/.gitkeep
!/template/env/*.example
!/template/env/*.template

###############################################################################
# Credentials n8n
###############################################################################

/template/n8n/credentials/*
!/template/n8n/credentials/.gitkeep
!/template/n8n/credentials/*.template.json

###############################################################################
# Workflows n8n
#
# Seuls les workflows explicitement transformés en modèles sont versionnés.
###############################################################################

/template/n8n/workflows/*
!/template/n8n/workflows/.gitkeep
!/template/n8n/workflows/*.template.json

###############################################################################
# Seeds SQL spécifiques aux restaurants
###############################################################################

/template/sql/seeds/*
!/template/sql/seeds/.gitkeep
!/template/sql/seeds/README.md
!/template/sql/seeds/*.template.sql

###############################################################################
# IDE
###############################################################################

.vscode/
.idea/
.DS_Store
Thumbs.db
