        "jsCode": "const body = $json.body ?? $json;\n\nfunction toNull(v) {\n  return v === undefined || v === null || v === '' ? null : v;\n}\n\nreturn [{\n  json: {\n    source: toNull(body.source),\n    channel: toNull(body.channel) ?? toNull(body.source),\n    restaurant_slug: toNull(body.restaurant_slug),\n    to: toNull(body.to),\n    from: toNull(body.from),\n    phone: toNull(body.phone) ?? toNull(body.from),\n    email: toNull(body.email),\n    full_name: toNull(body.full_name),\n    message: toNull(body.message) ?? '',\n    raw_message: toNull(body.message) ?? '',\n    intent: toNull(body.intent) ?? 'reservation_request',\n    requested_datetime: toNull(body.requested_datetime),\n    party_size: body.party_size ?? null,\n    special_request: toNull(body.special_request),\n    call_id: toNull(body.call_id),\n    call_status: toNull(body.call_status)\n  }\n}];"
